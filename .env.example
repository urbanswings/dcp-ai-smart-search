# Environment Configuration
ENVIRONMENT=PREPROD
COUNTRY=TR
LANGUAGE=TR
PRODUCT=NCOS
VEHICLE_CATEGORY=PASSENGER-CARS
PROJECT=EMH
API_ENDPOINT_LOCAL=false
X_API_KEY=your_x_api_key

# Test Mode Configuration
# Options: ui, api, both
TEST_MODE=ui
TEST_FACETS=true
FIXED_QUERIES_ONLY=false
OVERRIDE_CONFIG_FILE=true

# Playwright CDP (attach to existing browser)
# If set, UI tests attach to an already running Chrome instance
# started with --remote-debugging-port.
# Example: PLAYWRIGHT_CDP_URL=http://localhost:9222
# Alias supported: CDP_URL (alternative variable name)
PLAYWRIGHT_CDP_URL=http://localhost:9222
CDP_URL=http://localhost:9222

# Chrome profile (optional)
# Use your real Chrome profile to keep extensions/settings
# Be sure to QUIT Chrome first before using your real profile.
# Example paths (macOS):
#   CHROME_USER_DATA_DIR="$HOME/Library/Application Support/Google/Chrome"
#   CHROME_PROFILE_DIR=Default
CHROME_USER_DATA_DIR=
CHROME_PROFILE_DIR=

# Incognito mode for Playwright CDP attach (fresh incognito context)
# If true, Playwright will create a new incognito context when connecting
# over CDP instead of reusing the persistent context.
# Extensions generally do not run in incognito unless explicitly allowed.
PLAYWRIGHT_CDP_INCOGNITO=true
PLAYWRIGHT_USE_EXTENSION=true

# Authentication (for different environments)
DCP_USER_INT=your_username
DCP_PASS_INT=your_password
AEM_USER_PREPROD=your_username
AEM_PASS_PREPROD=your_password
AEM_USER_INT=your_username
AEM_PASS_INT=your_password

# LLM Configuration  
NEXUS_API_KEY=your_nexus_api_key_here
NEXUS_API_VERSION=your_nexus_api_version_here
NEXUS_API_ENDPOINT=your_nexus_api_endpoint_here
NEXUS_GPT_MODEL=your_nexus_gpt_model_here